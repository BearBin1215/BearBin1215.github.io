{
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "isolatedModules": true,
    "outDir": "dist",
    "rootDir": "./",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "useDefineForClassFields": true,
    "jsx": "react",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": ["vite/client"],
  },
  "include": [
    "src/**/*",
    "eslint.config.js",
    "vite.config.ts",
  ],
  "exclude": [
    "dist"
  ]
}
